<Window x:Class="LevelEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LevelEditor.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="{Binding WindowTitle}"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- Menu Style -->
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="#666666"
                                           Margin="20,0,0,0"
                                           VerticalAlignment="Center"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       Focusable="False">
                                    <Border Background="#252526"
                                            BorderBrush="#3F3F46"
                                            BorderThickness="1">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A5A8A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global button style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton Style -->
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A5A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555"
                                                        CornerRadius="4"
                                                        Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#777777"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

    </Window.Resources>

    <Window.DataContext>
        <vm:EditorViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}"           Key="Z" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding RedoCommand}"           Key="Y" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding SaveLevelCommand}"      Key="S" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding OpenLevelCommand}"      Key="O" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding NewLevelCommand}"       Key="N" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding ExportForUnityCommand}" Key="E" Modifiers="Ctrl"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- Top toolbar -->
        <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" Height="36">

            <Menu Background="Transparent" VerticalAlignment="Center" Margin="4,0">
                <MenuItem Header="📂 File" Foreground="#D4D4D4" Background="#2D2D2D">
                    <MenuItem Header="New"              Command="{Binding NewLevelCommand}"       InputGestureText="Ctrl+N"/>
                    <MenuItem Header="Open"             Command="{Binding OpenLevelCommand}"      InputGestureText="Ctrl+O"/>
                    <MenuItem Header="Save"             Command="{Binding SaveLevelCommand}"      InputGestureText="Ctrl+S"/>
                    <MenuItem Header="Save As"          Command="{Binding SaveLevelAsCommand}"/>
                    <Separator/>
                    <MenuItem Header="Export for Unity" Command="{Binding ExportForUnityCommand}" InputGestureText="Ctrl+E"/>
                    <Separator/>
                    <MenuItem Header="Recent Files" ItemsSource="{Binding RecentFiles}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding}"/>
                                <Setter Property="Command"
                                        Value="{Binding DataContext.OpenRecentFileCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter Property="CommandParameter" Value="{Binding}"/>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="❓ Help" Foreground="#D4D4D4" Background="#2D2D2D">
                    <MenuItem Header="Keyboard Shortcuts" Click="ShowShortcuts_Click"/>
                    <MenuItem Header="About"              Click="ShowAbout_Click"/>
                </MenuItem>
            </Menu>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Button Command="{Binding UndoCommand}"
                        Content="↩ Undo" IsEnabled="{Binding CanUndo}"
                        Padding="8,4" Margin="2,0"/>
                <Button Command="{Binding RedoCommand}"
                        Content="↪ Redo" IsEnabled="{Binding CanRedo}"
                        Padding="8,4" Margin="2,0"/>
                <Separator Width="1" Background="#555" Margin="6,4"/>
                <ToggleButton IsChecked="{Binding IsEntityMode}"
                              Content="👾 Entity Mode"
                              Padding="8,4" Margin="2,0"
                              ToolTip="Switch between tile and entity placement"/>
                <ToggleButton IsChecked="{Binding ShowCoordinates}"
                              Content="# Coords"
                              Padding="8,4" Margin="2,0"
                              ToolTip="Toggle grid coordinates"/>
            </StackPanel>

        </DockPanel>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ZoomText}" FontSize="12" Margin="0,0,10,0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="220" MinWidth="150" MaxWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: palette -->
            <Border Grid.Column="0" Background="#252526"
                    BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PALETTE" FontSize="11"
                               FontWeight="Bold" Foreground="#9CDCFE"
                               Margin="10,8,0,4"/>

                    <!-- Tile palette -->
                    <ScrollViewer Grid.Row="1"
                                  Visibility="{Binding TilePaletteVisibility}"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TileDefinitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="TileButton_Click"
                                            Tag="{Binding}"
                                            Margin="4,2"
                                            HorizontalContentAlignment="Left">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Foreground" Value="#D4D4D4"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="3"
                                                                    Padding="4,3">
                                                                <ContentPresenter HorizontalAlignment="Left"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#2A2D2E"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#094771"/>
                                                        <Setter Property="BorderBrush" Value="#007ACC"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <Border Width="18" Height="18"
                                                    Background="{Binding Color}"
                                                    CornerRadius="2"
                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Entity palette -->
                    <ScrollViewer Grid.Row="1"
                                  Visibility="{Binding EntityPaletteVisibility}"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="EntityPaletteItems"
                                      ItemsSource="{Binding EntityDefinitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="EntityButton_Click"
                                            Tag="{Binding}"
                                            Margin="4,2"
                                            HorizontalContentAlignment="Left">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Foreground" Value="#D4D4D4"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="3"
                                                                    Padding="4,3">
                                                                <ContentPresenter HorizontalAlignment="Left"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#2A2D2E"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <Border Width="18" Height="18"
                                                    Background="{Binding Color}"
                                                    CornerRadius="9"
                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#D4D4D4"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#3F3F46"/>

            <!-- Center: canvas -->
            <Border Grid.Column="2" Background="#1E1E1E" ClipToBounds="True"
                    x:Name="CanvasContainer">
                <Canvas x:Name="EditorCanvas"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseMove="Canvas_MouseMove"
                        MouseRightButtonDown="Canvas_MouseRightButtonDown"
                        MouseWheel="Canvas_MouseWheel"
                        Cursor="Cross">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ZoomTransform"
                                            ScaleX="{Binding Zoom}"
                                            ScaleY="{Binding Zoom}"/>
                            <TranslateTransform x:Name="PanTransform"
                                                X="{Binding OffsetX}"
                                                Y="{Binding OffsetY}"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="#3F3F46"/>

            <!-- Right panel: inspector -->
            <Border Grid.Column="4" Background="#252526"
                    BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="INSPECTOR" FontSize="11"
                               FontWeight="Bold" Foreground="#9CDCFE"
                               Margin="10,8,0,8"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">

                            <!-- Level properties -->
                            <TextBlock Text="Level" FontWeight="Bold"
                                       Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>

                            <TextBlock Text="Name" Foreground="#808080" FontSize="11"/>
                            <TextBox Text="{Binding Level.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3C3C3C" Foreground="White"
                                     BorderBrush="#555" Margin="0,2,0,8" Padding="4"/>

                            <TextBlock Text="Width (tiles)" Foreground="#808080" FontSize="11"/>
                            <TextBox Text="{Binding Level.Width}"
                                     Background="#3C3C3C" Foreground="White"
                                     BorderBrush="#555" Margin="0,2,0,8" Padding="4"/>

                            <TextBlock Text="Height (tiles)" Foreground="#808080" FontSize="11"/>
                            <TextBox Text="{Binding Level.Height}"
                                     Background="#3C3C3C" Foreground="White"
                                     BorderBrush="#555" Margin="0,2,0,8" Padding="4"/>

                            <Button Command="{Binding ResizeLevelCommand}"
                                    Content="Apply Resize"
                                    Padding="6,4" Margin="0,4,0,8"/>

                            <Separator Background="#3F3F46" Margin="0,8"/>

                            <!-- Layer list -->
                            <TextBlock Text="Layers" FontWeight="Bold"
                                       Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding Level.Layers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="32"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Click="LayerButton_Click"
                                                    Tag="{Binding}"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="6,4">
                                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                                            </Button>
                                            <ToggleButton Grid.Column="1"
                                                          IsChecked="{Binding IsVisible}"
                                                          Content="👁"
                                                          FontSize="11"
                                                          Click="LayerVisibility_Click"
                                                          Tag="{Binding}"
                                                          ToolTip="Toggle layer visibility"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="#3F3F46" Margin="0,8"/>

                            <!-- Selected tile info -->
                            <TextBlock Text="Selected" FontWeight="Bold"
                                       Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="20" Height="20"
                                        Background="{Binding SelectedTileColor}"
                                        CornerRadius="3" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding SelectedTileName}"
                                           Foreground="#D4D4D4" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Separator Background="#3F3F46" Margin="0,8"/>

                            <!-- Active layer -->
                            <TextBlock Text="Active Layer" Foreground="#808080" FontSize="11"/>
                            <TextBlock Text="{Binding ActiveLayer.Name}"
                                       Foreground="#9CDCFE" FontSize="13"
                                       FontWeight="Bold" Margin="0,2,0,8"/>

                            <!-- Entity properties -->
                            <StackPanel Visibility="{Binding EntityPropertiesVisibility}">
                                <Separator Background="#3F3F46" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Entity Properties"
                                               FontWeight="Bold" Foreground="#569CD6"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="🗑 Delete"
                                            Click="DeleteEntity_Click"
                                            Background="#6B1C1C" Foreground="White"
                                            BorderBrush="#8B2222" Padding="6,2"
                                            FontSize="11"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding EntityProperties}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Key}"
                                                           Foreground="#808080" FontSize="11"/>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#3C3C3C" Foreground="White"
                                                         BorderBrush="#555" Padding="4" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
