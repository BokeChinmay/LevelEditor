<Window x:Class="LevelEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LevelEditor.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="{Binding WindowTitle}"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="#1E1E1E">

    <Window.DataContext>
        <vm:EditorViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}" Key="Z" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding RedoCommand}" Key="Y" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding SaveLevelCommand}" Key="S" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding OpenLevelCommand}" Key="O" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding NewLevelCommand}" Key="N" Modifiers="Ctrl" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Top toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="#2D2D2D">
            <ToolBar Background="#2D2D2D" Foreground="White">
                <Button Command="{Binding NewLevelCommand}"    ToolTip="New (Ctrl+N)"   Content="🆕 New"    Margin="2"/>
                <Button Command="{Binding OpenLevelCommand}"   ToolTip="Open (Ctrl+O)"  Content="📂 Open"   Margin="2"/>
                <Button Command="{Binding SaveLevelCommand}"   ToolTip="Save (Ctrl+S)"  Content="💾 Save"   Margin="2"/>
                <Button Command="{Binding SaveLevelAsCommand}" ToolTip="Save As"        Content="💾 Save As" Margin="2"/>
                <Separator />
                <Button Command="{Binding UndoCommand}"        ToolTip="Undo (Ctrl+Z)"  Content="↩ Undo"    Margin="2"
                        IsEnabled="{Binding CanUndo}"/>
                <Button Command="{Binding RedoCommand}"        ToolTip="Redo (Ctrl+Y)"  Content="↪ Redo"    Margin="2"
                        IsEnabled="{Binding CanRedo}"/>
                <Separator />
                <Button Command="{Binding ExportForUnityCommand}" ToolTip="Export for Unity" Content="🎮 Export" Margin="2"/>
                <Separator />
                <ToggleButton IsChecked="{Binding IsEntityMode}" Content="👾 Entity Mode" Margin="2"
                              ToolTip="Switch between tile and entity placement"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ZoomText}" FontSize="12" Margin="0,0,10,0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="220" MinWidth="150" MaxWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: tile/entity palette -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PALETTE" FontSize="11"
                               FontWeight="Bold" Foreground="#9CDCFE"
                               Margin="10,8,0,4"/>

                    <!-- Tile palette -->
                    <ScrollViewer Visibility="{Binding TilePaletteVisibility}">
                        <ItemsControl ItemsSource="{Binding TileDefinitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="TileButton_Click"
                                            Tag="{Binding}"
                                            Margin="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <Border Width="18" Height="18"
                                                    Background="{Binding Color}"
                                                    CornerRadius="2"
                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#D4D4D4"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Entity palette -->
                    <ScrollViewer Visibility="{Binding EntityPaletteVisibility}">
                        <ItemsControl ItemsSource="{Binding EntityDefinitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="EntityButton_Click"
                                            Tag="{Binding}"
                                            Margin="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <Border Width="18" Height="18"
                                                    Background="{Binding Color}"
                                                    CornerRadius="9"
                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#D4D4D4"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#3F3F46"/>

            <!-- Center: canvas -->
            <Border Grid.Column="2" Background="#1E1E1E" ClipToBounds="True"
                    x:Name="CanvasContainer">
                <Canvas x:Name="EditorCanvas"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseMove="Canvas_MouseMove"
                        MouseRightButtonDown="Canvas_MouseRightButtonDown"
                        MouseWheel="Canvas_MouseWheel"
                        Cursor="Cross">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ZoomTransform"
                                            ScaleX="{Binding Zoom}"
                                            ScaleY="{Binding Zoom}"/>
                            <TranslateTransform x:Name="PanTransform"
                                                X="{Binding OffsetX}"
                                                Y="{Binding OffsetY}"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="#3F3F46"/>

            <!-- Right panel: inspector -->
            <Border Grid.Column="4" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="INSPECTOR" FontSize="11"
                               FontWeight="Bold" Foreground="#9CDCFE"
                               Margin="10,8,0,8"/>

                    <ScrollViewer>
                        <StackPanel Margin="8">

                            <!-- Level properties -->
                            <TextBlock Text="Level" FontWeight="Bold"
                                       Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>

                            <TextBlock Text="Name" Foreground="#808080" FontSize="11"/>
                            <TextBox Text="{Binding Level.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3C3C3C" Foreground="White"
                                     BorderBrush="#555" Margin="0,2,0,8" Padding="4"/>

                            <TextBlock Text="Width (tiles)" Foreground="#808080" FontSize="11"/>
                            <TextBox Text="{Binding Level.Width}"
                                     Background="#3C3C3C" Foreground="White"
                                     BorderBrush="#555" Margin="0,2,0,8" Padding="4"/>

                            <TextBlock Text="Height (tiles)" Foreground="#808080" FontSize="11"/>
                            <TextBox Text="{Binding Level.Height}"
                                     Background="#3C3C3C" Foreground="White"
                                     BorderBrush="#555" Margin="0,2,0,8" Padding="4"/>

                            <Separator Background="#3F3F46" Margin="0,8"/>

                            <!-- Layer list -->
                            <TextBlock Text="Layers" FontWeight="Bold"
                                       Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding Level.Layers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="LayerButton_Click"
                                                Tag="{Binding}"
                                                Margin="0,2"
                                                Background="#3C3C3C"
                                                Foreground="White"
                                                BorderBrush="#555"
                                                HorizontalContentAlignment="Left"
                                                Padding="6,4">
                                            <TextBlock Text="{Binding Name}" FontSize="12"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="#3F3F46" Margin="0,8"/>

                            <!-- Selected tile info -->
                            <TextBlock Text="Selected" FontWeight="Bold"
                                       Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="20" Height="20"
                                        Background="{Binding SelectedTileColor}"
                                        CornerRadius="3" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding SelectedTileName}"
                                           Foreground="#D4D4D4" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Separator Background="#3F3F46" Margin="0,8"/>

                            <!-- Active layer -->
                            <TextBlock Text="Active Layer" Foreground="#808080" FontSize="11"/>
                            <TextBlock Text="{Binding ActiveLayer.Name}"
                                       Foreground="#9CDCFE" FontSize="13"
                                       FontWeight="Bold" Margin="0,2,0,8"/>

                            <!-- Entity properties (visible when entity selected) -->
                            <StackPanel Visibility="{Binding EntityPropertiesVisibility}">
                                <Separator Background="#3F3F46" Margin="0,0,0,8"/>
                                <TextBlock Text="Entity Properties" FontWeight="Bold"
                                           Foreground="#569CD6" FontSize="12" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding SelectedEntityProperties}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Key}"
                                                           Foreground="#808080" FontSize="11"/>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#3C3C3C" Foreground="White"
                                                         BorderBrush="#555" Padding="4" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>