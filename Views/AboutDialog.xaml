<Window x:Class="LevelEditor.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Level Editor"
        Height="280" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <StackPanel Margin="32">
        <TextBlock Text="Level Editor" FontSize="24" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,8"/>
        <TextBlock Text="A 2D tile-based level editor for game development."
                   Foreground="#9D9D9D" TextWrapping="Wrap"
                   Margin="0,0,0,16" FontSize="13"/>
        <Separator Background="#3F3F46" Margin="0,0,0,16"/>
        <TextBlock Foreground="#9D9D9D" FontSize="12" Margin="0,0,0,6">
            <Run Text="Built with: "/>
            <Run Text="C# / WPF / .NET 9" Foreground="#9CDCFE"/>
        </TextBlock>
        <TextBlock Foreground="#9D9D9D" FontSize="12" Margin="0,0,0,6">
            <Run Text="Pattern: "/>
            <Run Text="MVVM + Command Pattern" Foreground="#9CDCFE"/>
        </TextBlock>
        <TextBlock Foreground="#9D9D9D" FontSize="12" Margin="0,0,0,6">
            <Run Text="Export: "/>
            <Run Text="JSON (native + Unity format)" Foreground="#9CDCFE"/>
        </TextBlock>
        <Separator Background="#3F3F46" Margin="0,16"/>
        <Button Content="Close" Click="Close_Click"
                HorizontalAlignment="Right"
                Background="#3C3C3C" Foreground="White"
                BorderBrush="#555" Padding="16,6"/>
    </StackPanel>
</Window>